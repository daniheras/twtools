---
// CardDeck.astro - 3D card stack with flip animation
// Front face shows "Faction Deck" cover, back face populated by JS
---

<div class="card-deck" id="card-deck">
  <div class="card-deck__glow"></div>
  <div class="card-deck__stack">
    <!-- 3 shadow cards behind the main card -->
    <div class="card-deck__shadow-card card-deck__shadow-card--1"></div>
    <div class="card-deck__shadow-card card-deck__shadow-card--2"></div>
    <div class="card-deck__shadow-card card-deck__shadow-card--3"></div>

    <div class="card-deck__lifter">
      <div class="card-deck__flipper">
        <!-- Front face: "Faction Deck" cover -->
        <div class="card-deck__face card-deck__face--front">
          <!-- Corner ornaments -->
          <svg class="card-deck__corner-svg card-deck__corner-svg--tl" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--tr" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--br" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--bl" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <!-- Center decorative element -->
          <div class="card-deck__front-emblem">
            <div class="card-deck__front-diamond-ring"></div>
            <div class="card-deck__front-diamond"></div>
          </div>
          <div class="card-deck__front-title">Faction Deck</div>
          <div class="card-deck__front-subtitle">Warhammer III</div>
          <div class="card-deck__front-line"></div>
        </div>

        <!-- Back face: empty container, filled by JS -->
        <div class="card-deck__face card-deck__face--back" id="card-back">
          <!-- Corner ornaments -->
          <svg class="card-deck__corner-svg card-deck__corner-svg--tl" width="32" height="32" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--tr" width="32" height="32" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--br" width="32" height="32" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>

          <svg class="card-deck__corner-svg card-deck__corner-svg--bl" width="32" height="32" viewBox="0 0 30 30" fill="none">
            <path d="M2 13 V5 Q2 2 5 2 H13" stroke="#c9a44e" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M7 16 V9.5 Q7 7 9.5 7 H16" stroke="#b8923c" stroke-width="1" stroke-linecap="round"/>
            <path d="M13 2 Q20 3 21 10" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M2 13 Q3 20 10 21" stroke="#c9a44e" stroke-width="1.2" stroke-linecap="round"/>
            <rect x="0" y="0" width="5" height="5" transform="rotate(45 2.5 2.5)" fill="#e0c266"/>
          </svg>
          <!-- Content filled dynamically by JS -->
        </div>
      </div>
    </div>
  </div>
</div>
