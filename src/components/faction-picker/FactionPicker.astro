---
import CardDeck from './CardDeck.astro';
import PoolPanel from './PoolPanel.astro';
import FilterPanel from './FilterPanel.astro';
import HistoryBar from './HistoryBar.astro';
---

<div class="picker" id="faction-picker">
  <!-- Arcane background SVG -->
  <div class="picker__bg">
    <svg width="660" height="660" viewBox="0 0 600 600" fill="none">
      <circle cx="300" cy="300" r="293" stroke="#c9a44e" stroke-width="1" stroke-dasharray="1.5 12"/>
      <circle cx="300" cy="300" r="259" stroke="#c9a44e" stroke-width="1"/>
      <circle cx="300" cy="300" r="252" stroke="#c9a44e" stroke-width="0.6" stroke-dasharray="0.8 7"/>
      <circle cx="300" cy="300" r="200" stroke="#c9a44e" stroke-width="1" stroke-dasharray="1 9"/>
      <circle cx="300" cy="300" r="148" stroke="#c9a44e" stroke-width="1"/>
      <path d="M300 14 L300 586 M14 300 L586 300" stroke="#c9a44e" stroke-width="1"/>
      <path d="M85 85 L515 515 M515 85 L85 515" stroke="#c9a44e" stroke-width="0.6"/>
      <path d="M300 88 L356 300 L300 512 L244 300 Z" stroke="#c9a44e" stroke-width="1"/>
      <path d="M88 300 L300 244 L512 300 L300 356 Z" stroke="#c9a44e" stroke-width="1"/>
      <circle cx="300" cy="300" r="22" stroke="#c9a44e" stroke-width="1"/>
      <circle cx="300" cy="300" r="6" fill="#c9a44e"/>
    </svg>
  </div>

  <!-- Corner decorations -->
  <div class="picker__corner picker__corner--tl"></div>
  <div class="picker__corner picker__corner--tr"></div>
  <div class="picker__corner picker__corner--bl"></div>
  <div class="picker__corner picker__corner--br"></div>

  <!-- Main scrollable content -->
  <div class="picker__scroll">
    <div class="picker__content">
      <!-- Main area: pool panel + card deck + filter panel -->
      <div class="picker__main">
        <div class="picker__side picker__side--left" id="panel-left">
          <PoolPanel />
        </div>

        <div class="picker__center">
          <div class="picker__spacer"></div>
          <CardDeck />
          <div class="picker__hint" id="action-hint">Click the deck to draw</div>
          <div class="picker__controls">
            <div class="picker__filter-toggle" id="filter-toggle">
              Filters<span class="picker__filter-chevron" id="filter-chevron">▾</span>
            </div>
          </div>
        </div>

        <div class="picker__side picker__side--right" id="panel-right">
          <FilterPanel />
        </div>
      </div>

      <!-- Footer inside picker -->
      <footer class="footer">
        Unofficial fan-made companion · not affiliated with the rights holders of Total War
      </footer>
    </div>
  </div>

  <!-- History bar -->
  <HistoryBar />

  <!-- Dust particles (generated by JS) -->
  <div class="picker__dust" id="dust-container"></div>

  <!-- CRT overlay -->
  <div class="crt-overlay">
    <div class="crt-overlay__scanlines"></div>
    <div class="crt-overlay__vignette"></div>
    <div class="crt-overlay__flicker"></div>
    <div class="crt-overlay__grain"></div>
  </div>
</div>

<script>
  // ============================================================
  // Faction Picker - Client-side Logic
  // ============================================================

  const ALLIANCE_COLORS: Record<string, string> = { Order:'#5fb0d4', Destruction:'#d4622e', Chaos:'#b15bd1' };

  interface FactionArt {
    lord: string;
    emblem: string;
    lordStyle: string;
  }

  interface Faction {
    id: string;
    name: string;
    lord: string;
    race: string;
    alliance: string;
    dlc: string;
    emblem: string;
    art?: FactionArt;
  }

  const FACTIONS: Faction[] = [
    {id:'reikland', name:'Reikland', lord:'Karl Franz', race:'The Empire', alliance:'Order', dlc:'base', emblem:'RE'},
    {id:'karaz', name:'Karaz-a-Karak', lord:'Thorgrim Grudgebearer', race:'Dwarfs', alliance:'Order', dlc:'base', emblem:'KK'},
    {id:'icecourt', name:'The Ice Court', lord:'Tzarina Katarin', race:'Kislev', alliance:'Order', dlc:'base', emblem:'IC'},
    {id:'cathay', name:'Northern Provinces', lord:'Miao Ying', race:'Grand Cathay', alliance:'Order', dlc:'base', emblem:'NP'},
    {id:'lothern', name:'Lothern', lord:'Tyrion', race:'High Elves', alliance:'Order', dlc:'base', emblem:'LO'},
    {id:'hexoatl', name:'Hexoatl', lord:'Lord Mazdamundi', race:'Lizardmen', alliance:'Order', dlc:'base', emblem:'HX'},
    {id:'naggarond', name:'Naggarond', lord:'Malekith', race:'Dark Elves', alliance:'Destruction', dlc:'base', emblem:'NG'},
    {id:'clanmors', name:'Clan Mors', lord:'Queek Headtaker', race:'Skaven', alliance:'Destruction', dlc:'base', emblem:'CM'},
    {id:'greenskins', name:'Greenskins', lord:'Grimgor Ironhide', race:'Orcs & Goblins', alliance:'Destruction', dlc:'base', emblem:'GS'},
    {id:'sylvania', name:'Sylvania', lord:'Vlad von Carstein', race:'Vampire Counts', alliance:'Destruction', dlc:'base', emblem:'SY'},
    {id:'khorne', name:'Exiles of Khorne', lord:'Skarbrand', race:'Daemons of Khorne', alliance:'Chaos', dlc:'base', emblem:'KH'},
    {id:'tzeentch', name:'Oracles of Tzeentch', lord:'Kairos Fateweaver', race:'Daemons of Tzeentch', alliance:'Chaos', dlc:'base', emblem:'TZ'},
    {id:'khemri', name:'Khemri', lord:'Settra the Imperishable', race:'Tomb Kings', alliance:'Destruction', dlc:'tk', emblem:'KM'},
    {id:'vcoast', name:'The Awakened', lord:'Cylostra Direfin', race:'Vampire Coast', alliance:'Destruction', dlc:'vc', emblem:'AW'},
    {id:'woodelves', name:'Argwylon', lord:'Durthu', race:'Wood Elves', alliance:'Order', dlc:'we', emblem:'AR'},
    {id:'norsca', name:'Wintertooth', lord:'Throgg', race:'Norsca', alliance:'Destruction', dlc:'no', emblem:'WT'},
    {id:'ogres', name:'Goldtooth', lord:'Greasus Goldtooth', race:'Ogre Kingdoms', alliance:'Destruction', dlc:'og', emblem:'GT'},
    {id:'chaosdwarfs', name:'Zharr-Naggrund', lord:'Astragoth Ironhand', race:'Chaos Dwarfs', alliance:'Chaos', dlc:'cd', emblem:'ZN', art:{lord:'/assets/lords/chaosdwarfs.png', emblem:'/assets/emblems/chaosdwarfs.png', lordStyle:'width:118%;aspect-ratio:801/1150;left:50%;bottom:5%;transform:translateX(-50%)'}}
  ];

  const DLCS = [
    {id:'base', label:'Base Game'},
    {id:'tk', label:'Rise of the Tomb Kings'},
    {id:'vc', label:'Curse of the Vampire Coast'},
    {id:'we', label:'Realm of the Wood Elves'},
    {id:'no', label:'Norsca'},
    {id:'og', label:'Ogre Kingdoms'},
    {id:'cd', label:'Forge of the Chaos Dwarfs'}
  ];

  // --- State ---
  type Phase = 'idle' | 'shuffling' | 'revealing' | 'revealed';

  let phase: Phase = 'idle';
  let drawn: Faction | null = null;
  const alliances: Record<string, boolean> = { Order: true, Destruction: true, Chaos: true };
  const dlcs: Record<string, boolean> = { base: true, tk: true, vc: true, we: true, no: true, og: true, cd: true };
  const excluded: Record<string, boolean> = {};
  let history: Faction[] = [];
  let filtersOpen = false;
  let _t1: ReturnType<typeof setTimeout> | null = null;
  let _t2: ReturnType<typeof setTimeout> | null = null;

  // --- DOM references ---
  const cardDeck = document.getElementById('card-deck')!;
  const cardBack = document.getElementById('card-back')!;
  const actionHint = document.getElementById('action-hint')!;
  const filterToggle = document.getElementById('filter-toggle')!;
  const filterChevron = document.getElementById('filter-chevron')!;
  const panelLeft = document.getElementById('panel-left')!;
  const panelRight = document.getElementById('panel-right')!;
  const poolCount = document.getElementById('pool-count')!;
  const historyBar = document.getElementById('history-bar')!;
  const dustContainer = document.getElementById('dust-container')!;
  const resetFiltersBtn = document.getElementById('reset-filters')!;
  const includeAllBtn = document.getElementById('pool-include-all')!;
  const excludeAllBtn = document.getElementById('pool-exclude-all')!;

  // --- Helpers ---
  function hexA(hex: string, a: number): string {
    const h = hex.replace('#', '');
    const n = parseInt(h.length === 3 ? h.split('').map(c => c + c).join('') : h, 16);
    return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`;
  }

  function availableByFilters(): Faction[] {
    return FACTIONS.filter(f => alliances[f.alliance] && dlcs[f.dlc]);
  }

  function pool(): Faction[] {
    return availableByFilters().filter(f => !excluded[f.id]);
  }

  // --- Render functions ---
  function updateCardDeck() {
    const stack = cardDeck.querySelector('.card-deck__stack') as HTMLElement;
    const lifter = cardDeck.querySelector('.card-deck__lifter') as HTMLElement;
    const flipper = cardDeck.querySelector('.card-deck__flipper') as HTMLElement;
    const shadowCards = cardDeck.querySelectorAll('.card-deck__shadow-card');

    // Shuffle animation on shadow cards and main card
    shadowCards.forEach(el => {
      (el as HTMLElement).style.animationName = phase === 'shuffling' ? 'tw-shuffle' : '';
    });
    lifter.style.animationName = phase === 'shuffling' ? 'tw-shuffle' : '';

    // Lift
    lifter.style.transform = (phase === 'revealing' || phase === 'revealed') ? 'translateY(-14px) scale(1.04)' : '';

    // Flip
    flipper.style.transform = phase === 'revealed' ? 'rotateY(180deg)' : '';

    // Cursor
    const p = pool();
    const busy = phase === 'shuffling' || phase === 'revealing';
    stack.style.cursor = (p.length === 0 || busy) ? 'default' : 'pointer';

    // Render back face
    if (drawn) {
      const col = ALLIANCE_COLORS[drawn.alliance];
      if (drawn.art) {
        cardBack.innerHTML = `
          <div class="card-deck__alliance-glow" style="background:radial-gradient(64% 46% at 50% 36%,${hexA(col, 0.22)} 0%,rgba(0,0,0,0) 72%)"></div>
          <div class="card-deck__lord-art" style="${drawn.art.lordStyle};background-image:url('${drawn.art.lord}')"></div>
          <div class="card-deck__lord-gradient"></div>
          <div class="card-deck__faction-info">
            <div class="card-deck__emblem" style="background-image:url('${drawn.art.emblem}')"></div>
            <div class="card-deck__faction-name">${drawn.name}</div>
            <div class="card-deck__divider">
              <div class="card-deck__divider-line card-deck__divider-line--left"></div>
              <div class="card-deck__divider-diamond"></div>
              <div class="card-deck__divider-line card-deck__divider-line--right"></div>
            </div>
            <div class="card-deck__lord-name">${drawn.lord}</div>
            <div class="card-deck__faction-meta">
              <span class="card-deck__meta-race">${drawn.race}</span>
              <span class="card-deck__meta-diamond" style="background:${col}"></span>
              <span class="card-deck__meta-alliance" style="color:${col}">${drawn.alliance}</span>
            </div>
          </div>`;
      } else {
        cardBack.innerHTML = `
          <div class="card-deck__no-art">
            <div class="card-deck__crest" style="border-color:${col};color:${col};background:radial-gradient(circle at 50% 34%,#fffaf0,${hexA(col, 0.1)});box-shadow:0 0 0 4px #f8f0dd,0 0 0 5px ${hexA(col, 0.5)},0 8px 18px rgba(0,0,0,.25)">${drawn.emblem}</div>
            <div class="card-deck__faction-name">${drawn.name}</div>
            <div class="card-deck__divider">
              <div class="card-deck__divider-line card-deck__divider-line--left"></div>
              <div class="card-deck__divider-diamond"></div>
              <div class="card-deck__divider-line card-deck__divider-line--right"></div>
            </div>
            <div class="card-deck__lord-name">${drawn.lord}</div>
            <div class="card-deck__faction-meta">
              <span class="card-deck__meta-race">${drawn.race}</span>
              <span class="card-deck__meta-diamond" style="background:${col}"></span>
              <span class="card-deck__meta-alliance" style="color:${col}">${drawn.alliance}</span>
            </div>
          </div>`;
      }
    }
  }

  function updateHint() {
    const p = pool();
    const busy = phase === 'shuffling' || phase === 'revealing';
    if (p.length === 0) {
      actionHint.textContent = 'Pool empty — open Filters to add factions';
      actionHint.style.color = '#cf7a45';
    } else if (busy) {
      actionHint.textContent = 'Consulting the deck…';
      actionHint.style.color = '';
    } else if (phase === 'revealed') {
      actionHint.textContent = 'Click the deck to draw again';
      actionHint.style.color = '';
    } else {
      actionHint.textContent = 'Click the deck to draw';
      actionHint.style.color = '';
    }
  }

  function updateFiltersUI() {
    // Toggle button state
    filterToggle.classList.toggle('picker__filter-toggle--active', filtersOpen);
    filterChevron.style.transform = filtersOpen ? 'rotate(180deg)' : '';

    // Show/hide panels
    panelLeft.style.display = filtersOpen ? '' : 'none';
    panelRight.style.display = filtersOpen ? '' : 'none';
  }

  function updatePoolPanel() {
    const avail = availableByFilters();
    const p = pool();
    poolCount.textContent = String(p.length);

    // Update tile states
    document.querySelectorAll('.pool-panel__tile').forEach(tile => {
      const el = tile as HTMLElement;
      const fid = el.dataset.factionId!;
      const faction = FACTIONS.find(f => f.id === fid)!;
      const isAvail = avail.some(f => f.id === fid);
      const isExcluded = !!excluded[fid];

      el.style.display = isAvail ? '' : 'none';
      el.style.opacity = isExcluded ? '0.3' : '1';
      const col = ALLIANCE_COLORS[faction.alliance];
      el.style.borderColor = isExcluded ? '#2a2419' : hexA(col, 0.5);
    });
  }

  function updateFilterPanel() {
    // Alliance chips
    document.querySelectorAll('.filter-panel__chip').forEach(chip => {
      const el = chip as HTMLElement;
      const alliance = el.dataset.alliance!;
      const on = alliances[alliance];
      const col = ALLIANCE_COLORS[alliance];

      if (on) {
        el.classList.add('filter-panel__chip--active');
        el.style.borderColor = col;
        el.style.background = hexA(col, 0.16);
        el.style.color = col;
      } else {
        el.classList.remove('filter-panel__chip--active');
        el.style.borderColor = '#3a3324';
        el.style.background = 'rgba(255,255,255,.02)';
        el.style.color = '#6a6453';
      }

      const dot = el.querySelector('.filter-panel__chip-dot') as HTMLElement;
      if (dot) {
        dot.style.background = on ? col : '#6a6453';
        dot.style.boxShadow = on ? `0 0 8px ${col}` : 'none';
      }
    });

    // DLC rows
    document.querySelectorAll('.filter-panel__dlc-row').forEach(row => {
      const el = row as HTMLElement;
      const dlcId = el.dataset.dlc!;
      const on = dlcs[dlcId];
      el.style.opacity = on ? '1' : '0.5';

      const checkbox = el.querySelector('.filter-panel__checkbox') as HTMLElement;
      if (checkbox) {
        checkbox.textContent = on ? '✓' : '';
        checkbox.classList.toggle('filter-panel__checkbox--checked', on);
      }

      const label = el.querySelector('.filter-panel__dlc-label') as HTMLElement;
      if (label) {
        label.style.color = on ? '#cbc6b4' : '#8a8674';
        label.style.textDecoration = on ? '' : 'line-through';
      }
    });
  }

  function updateHistory() {
    if (history.length === 0) {
      historyBar.style.display = 'none';
      return;
    }
    historyBar.style.display = '';
    // Keep label, rebuild items
    const label = historyBar.querySelector('.history-bar__label')!;
    historyBar.innerHTML = '';
    historyBar.appendChild(label);

    history.forEach(f => {
      const col = ALLIANCE_COLORS[f.alliance];
      const item = document.createElement('div');
      item.className = 'history-bar__item';
      item.title = f.name;
      item.style.borderColor = hexA(col, 0.7);

      if (f.art?.emblem) {
        const icon = document.createElement('div');
        icon.className = 'history-bar__item-icon';
        icon.style.backgroundImage = `url('${f.art.emblem}')`;
        item.appendChild(icon);
      } else {
        const mono = document.createElement('span');
        mono.className = 'history-bar__item-monogram';
        mono.style.color = col;
        mono.textContent = f.emblem;
        item.appendChild(mono);
      }

      item.addEventListener('click', () => selectHistory(f));
      historyBar.appendChild(item);
    });
  }

  function render() {
    updateCardDeck();
    updateHint();
    updateFiltersUI();
    updatePoolPanel();
    updateFilterPanel();
    updateHistory();
  }

  // --- Actions ---
  function draw() {
    const p = pool();
    if (!p.length || phase === 'shuffling' || phase === 'revealing') return;
    const pick = p[Math.floor(Math.random() * p.length)];

    if (_t1) clearTimeout(_t1);
    if (_t2) clearTimeout(_t2);

    phase = 'shuffling';
    drawn = null;
    render();

    _t1 = setTimeout(() => {
      phase = 'revealing';
      drawn = pick;
      render();
    }, 1100);

    _t2 = setTimeout(() => {
      phase = 'revealed';
      history = [pick, ...history.filter(h => h.id !== pick.id)].slice(0, 5);
      render();
    }, 1580);
  }

  function selectHistory(f: Faction) {
    if (_t1) clearTimeout(_t1);
    if (_t2) clearTimeout(_t2);
    phase = 'revealed';
    drawn = f;
    render();
  }

  function toggleFilters() {
    filtersOpen = !filtersOpen;
    render();
  }

  function toggleAlliance(k: string) {
    alliances[k] = !alliances[k];
    render();
  }

  function toggleDlc(id: string) {
    dlcs[id] = !dlcs[id];
    render();
  }

  function toggleExclude(id: string) {
    excluded[id] = !excluded[id];
    render();
  }

  function includeAll() {
    Object.keys(excluded).forEach(k => delete excluded[k]);
    render();
  }

  function excludeAll() {
    availableByFilters().forEach(f => { excluded[f.id] = true; });
    render();
  }

  function resetFilters() {
    Object.keys(alliances).forEach(k => { alliances[k] = true; });
    Object.keys(dlcs).forEach(k => { dlcs[k] = true; });
    Object.keys(excluded).forEach(k => delete excluded[k]);
    render();
  }

  // --- Generate dust particles ---
  function generateDust() {
    const frac = (x: number) => Math.abs(Math.sin(x)) % 1;
    for (let i = 0; i < 12; i++) {
      const sz = (1 + frac(i + 3) * 2.2).toFixed(1);
      const particle = document.createElement('div');
      particle.className = 'picker__dust-particle';
      particle.style.left = `${frac(i + 1) * 100}%`;
      particle.style.top = `${frac(i + 7) * 100}%`;
      particle.style.width = `${sz}px`;
      particle.style.height = `${sz}px`;
      particle.style.background = `rgba(232,214,170,${(0.05 + frac(i + 5) * 0.1).toFixed(2)})`;
      particle.style.animationDuration = `${(8 + frac(i + 2) * 9).toFixed(1)}s`;
      particle.style.animationDelay = `${(-frac(i + 4) * 9).toFixed(1)}s`;
      dustContainer.appendChild(particle);
    }
  }

  // --- Event binding ---
  // Card deck click
  cardDeck.querySelector('.card-deck__stack')!.addEventListener('click', draw);

  // Filter toggle
  filterToggle.addEventListener('click', toggleFilters);

  // Pool tiles
  document.querySelectorAll('.pool-panel__tile').forEach(tile => {
    tile.addEventListener('click', () => {
      toggleExclude((tile as HTMLElement).dataset.factionId!);
    });
  });

  // Alliance chips
  document.querySelectorAll('.filter-panel__chip').forEach(chip => {
    chip.addEventListener('click', () => {
      toggleAlliance((chip as HTMLElement).dataset.alliance!);
    });
  });

  // DLC rows
  document.querySelectorAll('.filter-panel__dlc-row').forEach(row => {
    row.addEventListener('click', () => {
      toggleDlc((row as HTMLElement).dataset.dlc!);
    });
  });

  // Include/Exclude All
  includeAllBtn.addEventListener('click', includeAll);
  excludeAllBtn.addEventListener('click', excludeAll);

  // Reset filters
  resetFiltersBtn.addEventListener('click', resetFilters);

  // --- Init ---
  generateDust();
  panelLeft.style.display = 'none';
  panelRight.style.display = 'none';
  render();
</script>
